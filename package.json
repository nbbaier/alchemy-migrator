{
	"name": "alchemy-migrator",
	"version": "0.1.0",
	"description": "Migrate Cloudflare Wrangler projects to Alchemy",
	"type": "module",
	"bin": {
		"alchemy-migrator": "./dist/index.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "vitest --run",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest --coverage",
		"check": "biome check",
		"fix": "biome check --write",
		"lint": "biome lint",
		"format": "biome format --write"
	},
	"dependencies": {
		"@iarna/toml": "^2.2.5",
		"chalk": "^5.6.2",
		"commander": "^12.1.0",
		"jsonc-parser": "^3.3.1",
		"ora": "^8.2.0",
		"prettier": "^3.8.1",
		"prompts": "^2.4.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.6",
		"@types/bun": "latest",
		"@types/node": "^20.19.37",
		"@types/prompts": "^2.4.9",
		"@vitest/coverage-v8": "^1.6.1",
		"@vitest/ui": "^4.1.2",
		"fast-check": "^3.23.2",
		"tsdown": "^0.19.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"keywords": [
		"alchemy",
		"cloudflare",
		"wrangler",
		"migration",
		"infrastructure-as-code",
		"workers"
	],
	"module": "index.ts",
	"private": true
}
